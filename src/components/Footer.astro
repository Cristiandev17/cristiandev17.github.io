---
import AstroDark from '../assets/Astro_dark.svg';
import AstroLight from '../assets/Astro_light.svg';
import TailwindIcon from '../assets/tailwindcss.svg';

const translations = {
	built: {
		en: 'Built with',
		es: 'Construido con'
	},
	credits: {
		en: "© 2026 Cristian Camilo Aristizabal Tobon's Portfolio",
		es: "© 2026 Portafolio de Cristian Camilo Aristizabal Tobon"
	}
};
---

<footer class="border-t border-gray-200 dark:border-gray-800 py-6 sm:py-8 mt-12 sm:mt-20 bg-white dark:bg-gray-950 transition-colors duration-300">
	<div class="max-w-3xl mx-auto px-4 sm:px-6 md:px-6 text-center">
		<p class="text-xs sm:text-sm text-gray-600 dark:text-gray-400 mb-3 sm:mb-4" data-en={translations.credits.en} data-es={translations.credits.es}/>
	</div>
</footer>
