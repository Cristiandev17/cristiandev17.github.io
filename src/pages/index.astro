---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import heroPhoto from '../assets/wallpper.png';

const translations = {
  greeting: { 
    en: "Hello, I'm", 
    es: "Hola, soy" 
  },
  name: { 
    en: "Cristian Camilo Aristizabal Tobon", 
    es: "Cristian Camilo Aristizabal Tobon" 
  },
  description: { 
    en: "Software Developer with more than 11 years of experience, specialized in solution architecture and technical leadership in mobile and backend projects using .NET. Focused on designing scalable systems, applying best practices (Clean Architecture, SOLID principles, and design patterns), and guiding teams toward efficient and maintainable solutions.", 
    es: "Desarrollador de Software con más de 11 años de experiencia, especializado en arquitectura de soluciones y liderazgo técnico en proyectos móviles y backend con .NET. Enfocado en diseñar sistemas escalables, aplicar buenas prácticas (Clean Architecture, SOLID, patrones de diseño) y guiar equipos hacia soluciones eficientes y mantenibles." 
  },
  availability: {
    en: "Open to work",
    es: "Disponible para trabajar"
  },
  viewProjects: { 
    en: "View Projects", 
    es: "Ver Proyectos" 
  },
  getInTouch: { 
    en: "Get in Touch", 
    es: "Contactar" 
  },
  about: { 
    en: "About Me", 
    es: "Sobre mí" 
  },
  aboutDesc: {
    es: "Desarrollador de Software con más de 11 años de experiencia en el diseño, desarrollo y evolución de soluciones móviles y backend, utilizando tecnologías como .NET, Xamarin, .NET MAUI y Flutter. Especializado en arquitectura de software, definición de estándares técnicos y liderazgo de equipos de desarrollo. Cuento con experiencia en la construcción de APIs RESTful, implementación de autenticación con JWT, diseño de bases de datos SQL y NoSQL, y aplicación de principios como SOLID, Clean Architecture y patrones de diseño para garantizar escalabilidad, mantenibilidad y alto rendimiento. Me enfoco en la toma de decisiones arquitectónicas alineadas con los objetivos del negocio, promoviendo buenas prácticas, calidad de código y procesos de mejora continua dentro del equipo.",
    en: "I am a Full Stack Developer with experience building end-to-end web applications, from architecture design to implementation and deployment. I work integrating APIs, databases, and modern services, with a focus on performance, maintainability, and user experience. I adapt well to collaborative teams, follow development best practices, and aim to deliver stable solutions that bring real business value. I am interested in remote or hybrid opportunities where I can continue growing professionally and contribute to well-structured projects."
  },
  tech: { 
    en: "Tech Stack", 
    es: "Tecnologías" 
  }
};

---

<Layout title={`Home | Cristian Camilo Aristizabal Tobon`}>
	<Header />
	
	<main class="min-h-screen px-4 sm:px-6 md:px-6">
		<section class="max-w-3xl mx-auto min-h-[calc(100vh-5rem)] flex flex-col justify-center pt-32 sm:pt-48 pb-16 sm:pb-24 fade-in">
			<div class="flex flex-col items-center gap-6 sm:gap-8 text-center">
				<div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
					<div class="w-24 h-24 sm:w-28 sm:h-28 md:w-32 md:h-32 rounded-full bg-gray-100 dark:bg-gray-800 border-2 border-gray-300 dark:border-gray-600 flex items-center justify-center overflow-hidden animated-border always-visible flex-shrink-0 shadow-lg dark:shadow-white/20">
						<img src={heroPhoto.src} alt="Cristian Aristizabal" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
						<span class="text-2xl sm:text-3xl md:text-4xl text-gray-500 dark:text-gray-400 hidden">📷</span>
					</div>
					<div class="animated-border always-visible px-3 sm:px-4 py-2 rounded-full border border-gray-300 dark:border-gray-600 h-fit">
						<p class="text-xs sm:text-sm font-medium text-gray-900 dark:text-white whitespace-nowrap" data-en={translations.availability.en} data-es={translations.availability.es}>{translations.availability.en}</p>
					</div>
				</div>
				<div>
					<p class="text-xs sm:text-sm font-medium text-gray-600 dark:text-gray-400 mb-2" data-en={translations.greeting.en} data-es={translations.greeting.es}>{translations.greeting.en}</p>
					<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4 sm:mb-6 px-2 sm:px-0" data-en={translations.name.en} data-es={translations.name.es}>
						{translations.name.en}
					</h1>
					<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 max-w-lg mx-auto mb-4 sm:mb-6 px-2 sm:px-0" data-en={translations.description.en} data-es={translations.description.es}>						
					</p>
					<div class="flex flex-wrap gap-2 sm:gap-3 justify-center px-2 sm:px-0">
						<a href="/projects" class="cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-medium rounded-full hover:animated-bg transition-all" data-en={translations.viewProjects.en} data-es={translations.viewProjects.es}>
							{translations.viewProjects.en}
						</a>
						<a href="/contact" class="animated-border cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white font-medium rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" data-en={translations.getInTouch.en} data-es={translations.getInTouch.es}>
							{translations.getInTouch.en}
						</a>
					</div>
				</div>
			</div>
		</section>

		<section class="max-w-3xl mx-auto py-12 sm:py-16 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0">
			<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-6 sm:mb-8" data-en={translations.about.en} data-es={translations.about.es}>{translations.about.en}</h2>
			<div class="space-y-3 sm:space-y-4 text-base sm:text-lg leading-relaxed text-gray-600 dark:text-gray-400" data-en={translations.aboutDesc.en} data-es={translations.aboutDesc.es}>
				{translations.aboutDesc.en}
			</div>
		</section>

		<section class="max-w-3xl mx-auto py-12 sm:py-16 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0">
			<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-6 sm:mb-8" data-en={translations.tech.en} data-es={translations.tech.es}>{translations.tech.en}</h2>
			
			<div class="tech-ticker-container">
				<div class="tech-ticker-content">
					<!-- First set -->
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">JavaScript</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">TypeScript</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">React</p>
					</div>					
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Astro</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Tailwind CSS</p>
					</div>					
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">.Net Core</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">.Net MAUI</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Flutter</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">MongoDB</p>
					</div>					
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Git</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Semantic Kernel</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Microsoft Azure</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">APIs REST</p>
					</div>
					
					<!-- Second set for seamless looping -->
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">JavaScript</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">TypeScript</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">React</p>
					</div>					
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Astro</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Tailwind CSS</p>
					</div>					
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">.Net Core</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">.Net MAUI</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Flutter</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">MongoDB</p>
					</div>					
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Git</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Semantic Kernel</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Microsoft Azure</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">APIs REST</p>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const observerOptions = {
				root: null,
				rootMargin: '0px',
				threshold: 0.1
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
					}
				});
			}, observerOptions);

			document.querySelectorAll('.fade-in').forEach(el => {
				observer.observe(el);
			});

			window.addEventListener('scroll', () => {
				const scrolled = window.pageYOffset;
				document.querySelectorAll('.parallax-section').forEach(section => {
					const speed = 0.1;
					(section as HTMLElement).style.transform = `translateY(${scrolled * speed}px)`;
				});
			});
		});
	</script>
</Layout>
