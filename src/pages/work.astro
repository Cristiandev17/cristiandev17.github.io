---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const translations = {
    subtitle: { en: 'My Journey', es: 'Mi Trayectoria' },
    title: { en: 'Work Experience', es: 'Experiencia Laboral' },
    description: { en: 'A timeline of my professional journey and achievements.', es: 'Una línea de tiempo de mi trayectoria profesional y logros.' }
};

const workExperience = [
    {
        year: '04/2024 - Present',
        yearES: '04/2024 - Actualidad',
        title: 'Senior Leader Full Stack Contractor',
        titleES: 'Senior Leader Full Stack Contractor',
        company: 'Grecotech',
        description: 'I lead the development of SPA applications using React, TypeScript, and Tailwind, along with scalable RESTful APIs built with .NET 9 following Clean Architecture and DDD principles to ensure high performance and maintainability. I implemented JWT-based authentication, designed MongoDB data models, integrated cloud solutions on Azure, and incorporated AI capabilities using Semantic Kernel and Azure OpenAI for intelligent document analysis. Additionally, I developed cross-platform mobile applications with Flutter applying BLoC and Clean Architecture, and supported the team through technical mentorship and code reviews.',
        descriptionES: 'Lidero el desarrollo de aplicaciones SPA con React, TypeScript y Tailwind, junto con APIs RESTful en .NET 9 bajo Clean Architecture y DDD, asegurando escalabilidad y alto rendimiento. Implementé autenticación con JWT, modelado en MongoDB, integración con Azure y capacidades de IA usando Semantic Kernel y Azure OpenAI para análisis inteligente de documentos. Además, desarrollé aplicaciones móviles con Flutter aplicando BLoC y Clean Architecture, y apoyé al equipo mediante mentoría técnica y code reviews.'
    },
    {
        year: '10/2019 - 06/2025',
        yearES: '10/2019 - 06/2025',
        title: 'Application Development Instructor',
        titleES: 'Docente Desarrollo de Aplicaciones',
        company: 'Corporacion Tecnologica de Occidente',
        description: 'At this company, I was responsible for developing educational materials for Xamarin, .NET MAUI, and WPF, creating hands-on technical content focused on practical learning. I delivered training in React JS, frontend development, and .NET Core with RESTful APIs, helping participants strengthen their skills through real-world projects. Additionally, I promoted software architecture best practices, encouraging clean, scalable, and maintainable code',
        descriptionES: 'Fui responsable del desarrollo de material didáctico en Xamarin, .NET MAUI y WPF, creando contenidos prácticos enfocados en formación técnica. Impartí capacitación en React JS, desarrollo frontend y .NET Core con APIs RESTful, fortaleciendo las habilidades de los participantes en proyectos reales. Además, promoví buenas prácticas de arquitectura y desarrollo de software, fomentando código limpio, escalable y mantenible.'
    },
    {
        year: '08/2024 - 12/2024',
        yearES: '08/2024 - 12/2024',
        title: 'Full Stack Software Developer Contractor',
        titleES: 'Full Stack Software Developer Contractor',
        company: 'Foonkie Monkey',
        description: 'I was responsible for optimizing performance in cross-platform applications built with .NET MAUI, ensuring stability and efficiency. I handled ongoing maintenance, updates, and security improvements, as well as integrating RESTful APIs and external services based on business needs. I managed the mobile lifecycle end-to-end, including publishing and maintaining applications on the App Store and Play Store.',
        descriptionES: 'Fui responsable de la optimización de rendimiento en aplicaciones multiplataforma desarrolladas con .NET MAUI, asegurando estabilidad y eficiencia. Realicé mantenimiento continuo, actualizaciones y mejoras de seguridad, además de integrar APIs RESTful y servicios externos según los requerimientos del negocio. Gestioné el ciclo de vida móvil end-to-end, incluyendo publicación y administración en App Store y Play Store.'
    },
	{
        year: '03/2024 - 12/2024',
        yearES: '083/2024 - 12/2024',
        title: 'Full Stack Software Developer Contractor',
        titleES: 'Full Stack Software Developer Contractor',
        company: 'Neobit',
        description: 'I developed cross-platform mobile applications with Xamarin for Android and iOS, implementing local NoSQL databases with Realm and building advanced user interfaces using Syncfusion controls. I optimized performance, managed mobile resources, and executed cross-platform testing to ensure stability, while also providing corrective maintenance for .NET Blazor applications. I led the migration from Xamarin.Forms to Flutter, applying Clean Architecture, the BLoC pattern, dependency injection, and the Repository Pattern to integrate REST APIs and local storage solutions.',
        descriptionES: 'desarrollé aplicaciones móviles multiplataforma con Xamarin para Android e iOS, implementando bases de datos locales con Realm y construyendo interfaces avanzadas con controles de Syncfusion. Optimicé el rendimiento, gestioné recursos y ejecuté pruebas multiplataforma para garantizar estabilidad, además de realizar mantenimiento correctivo en aplicaciones .NET Blazor. Lideré la migración de Xamarin.Forms a Flutter, aplicando Clean Architecture, patrón BLoC, inyección de dependencias y Repository Pattern para integrar APIs REST y almacenamiento local.'
    }
];
---

<Layout title={`Work | Cristian Aristizabal`}>
	<Header />
	
	<main class="min-h-screen px-4 sm:px-6 md:px-6">
		<section class="max-w-3xl mx-auto min-h-[calc(100vh-5rem)] pt-24 sm:pt-32 md:pt-48 pb-16 sm:pb-24 fade-in px-2 sm:px-0">
			<div class="max-w-2xl mb-12 sm:mb-16">
				<p class="text-xs sm:text-sm font-medium text-gray-600 dark:text-gray-400 mb-3 sm:mb-4 tracking-wider uppercase" data-en={translations.subtitle.en} data-es={translations.subtitle.es}>{translations.subtitle.en}</p>
				<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 dark:text-white" data-en={translations.title.en} data-es={translations.title.es}>
					{translations.title.en}
				</h1>
				<p class="mt-3 sm:mt-4 text-sm sm:text-lg text-gray-600 dark:text-gray-400" data-en={translations.description.en} data-es={translations.description.es}>
					{translations.description.en}
				</p>
			</div>

			<div class="space-y-8 sm:space-y-12 parallax-section">
				{
					workExperience.map((work, index) => (
						<div class="relative pl-6 sm:pl-8 border-l-2 border-gray-200 dark:border-gray-700 bg-transparent group cursor-pointer hover:scale-105 transition-all">
							<div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-gray-400 dark:bg-gray-500 group-hover:scale-125 transition-transform"></div>
							<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-2 gap-2 sm:gap-0">
								<h3 class="text-lg sm:text-xl font-semibold text-gray-900 dark:text-white" data-en={work.title} data-es={work.titleES}>{work.title}</h3>
								<span class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 font-medium" data-en={work.year} data-es={work.yearES}>{work.year}</span>
							</div>
							<p class="text-sm sm:text-lg text-gray-600 dark:text-gray-400 font-medium mb-2 sm:mb-3">{work.company}</p>
							<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 leading-relaxed" data-en={work.description} data-es={work.descriptionES}>{work.description}</p>
						</div>
					))
				}
			</div>
		</section>
	</main>

	<Footer />

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const observerOptions = {
				root: null,
				rootMargin: '0px',
				threshold: 0.1
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
					}
				});
			}, observerOptions);

			document.querySelectorAll('.fade-in').forEach(el => {
				observer.observe(el);
			});

			window.addEventListener('scroll', () => {
				const scrolled = window.pageYOffset;
				document.querySelectorAll('.parallax-section').forEach(section => {
					const speed = 0.05;
					(section as HTMLElement).style.transform = `translateY(${scrolled * speed}px)`;
				});
			});
		});
	</script>
</Layout>
